# Rezepti – Beispiel-Konfiguration
# Kopiere diese Datei nach .env und trage deine Werte ein.
# Oder nutze die Setup-Seite unter /setup

# Optional: Verzeichnis für .env (z.B. bei Docker-Volume: /app/config)
# CONFIG_DIR=/app/config

# Server: 0.0.0.0 = von allen IPs erreichbar (z.B. http://192.168.1.168:3000)
# HOST=0.0.0.0

# Ollama (auf Host/anderem Rechner: IP statt localhost)
# OLLAMA_BASE_URL=http://192.168.1.168:11434

# yt-dlp: Pfad falls nicht in PATH (im Docker-Image: yt-dlp)
# YT_DLP_PATH=yt-dlp

# Export-Ziel: notion oder mealie
EXPORT_BACKEND=notion

# === Notion (wenn EXPORT_BACKEND=notion) ===
NOTION_TOKEN=
NOTION_DATABASE_ID=
NOTION_PARENT_PAGE_ID=

# === Mealie v1 (wenn EXPORT_BACKEND=mealie) ===
MEALIE_BASE_URL=
MEALIE_API_TOKEN=

# === Ollama (optional) ===
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_TEXT_MODEL=llama3.2:3b
OLLAMA_VISION_MODEL=llava:7b

# === LLM-Backend: "ollama" oder "llamacpp" ===
# LLM_PROVIDER=ollama

# === llama.cpp (OpenAI-kompatible API, ein Modell für Text + Vision) ===
LLAMACPP_BASE_URL=http://localhost:[LLAMAPORT]
LLAMACPP_VISION_MODEL=Qwen3VL-8B-Instruct-Q8_0.gguf

# Port
PORT=3003

# Whisper (optional, im Docker-Image bereits enthalten)
# WHISPER_MODEL_PATH=/opt/whisper/models/ggml-large-v3-turbo.bin
# WHISPER_CLI_PATH=whisper-cli
